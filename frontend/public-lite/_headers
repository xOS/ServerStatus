/assets/*
  Cache-Control: public, max-age=31536000, immutable

/static/*
  Cache-Control: no-cache, must-revalidate

/favicon.svg
  Cache-Control: no-cache, must-revalidate

/
  Cache-Control: no-store, max-age=0
  CDN-Cache-Control: no-store

/index.html
  Cache-Control: no-store, max-age=0
  CDN-Cache-Control: no-store

/login
  Cache-Control: no-store, max-age=0
  CDN-Cache-Control: no-store

/dashboard
  Cache-Control: no-store, max-age=0
  CDN-Cache-Control: no-store

/dashboard/*
  Cache-Control: no-store, max-age=0
  CDN-Cache-Control: no-store

/network
  Cache-Control: no-store, max-age=0
  CDN-Cache-Control: no-store

/network/*
  Cache-Control: no-store, max-age=0
  CDN-Cache-Control: no-store

/_asset-recovery/*
  Cache-Control: no-store, max-age=0
  CDN-Cache-Control: no-store
